rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: players
    // Fields:
    //   - name: string (required, 1-50 chars)
    //   - createdAt: number (required)
    //
    // Collection: records
    // Fields:
    //   - playerId: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - amount: number (required)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['name', 'createdAt']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 50 &&
             data.createdAt is number;
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['playerId', 'date', 'amount', 'createdAt']) &&
             data.playerId is string &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.amount is number &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /players/{playerId} {
      allow read: if true;
      allow create: if isValidPlayer(request.resource.data);
      allow update: if isValidPlayer(request.resource.data);
      allow delete: if true; // For now, let friends manage it
    }

    match /records/{recordId} {
      allow read: if true;
      allow create: if isValidRecord(request.resource.data);
      allow update: if isValidRecord(request.resource.data);
      allow delete: if true;
    }
  }
}
